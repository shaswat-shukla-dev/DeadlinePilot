# Copy this file to .env for local development
# In production, set these as App Engine environment variables (see app.yaml)
# or via: gcloud app deploy --set-env-vars KEY=VALUE

# Server
PORT=8080
NODE_ENV=development

# Google Gemini API (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your-gemini-api-key-here

# Google Cloud Project (for Firestore)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
FIRESTORE_DATABASE=(default)

# Google OAuth (for Calendar integration)
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-oauth-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8080/api/calendar/callback

# Frontend URL (for CORS + OAuth redirect)
FRONTEND_URL=http://localhost:3000
